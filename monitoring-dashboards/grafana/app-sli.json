{
  "title": "Sample App SLI",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "graph",
      "title": "HTTP P95 Latency (s)",
      "id": 1,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "graph",
      "title": "HTTP Error Rate (%)",
      "id": 2,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_errors_total[5m])) / sum(rate(http_server_requests_total[5m]))",
          "legendFormat": "error %"
        }
      ]
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
